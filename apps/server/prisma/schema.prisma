generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
  REJECTED
}

enum GroupType {
  DIRECTION
  GRADE
  FUNCTIONAL
  SYSTEM
}

enum MembershipRole {
  MEMBER
  MANAGER
}

enum SpaceVisibility {
  PUBLIC
  PRIVATE
  GROUP_RESTRICTED
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum KnowledgePageAccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum KnowledgePageAccessApproverKind {
  PAGE_OWNER
  SPACE_OWNER
  LAB_ADMIN
}

enum MailboxProvisioningStatus {
  PENDING
  PROVISIONED
  FAILED
}

enum InternalMailRecipientType {
  SENDER
  TO
  CC
}

enum InternalMailDeliverySourceType {
  USER
  GROUP
}

model User {
  id                        String                    @id @default(cuid())
  username                  String?                   @unique
  email                     String                    @unique
  notificationEmail         String?
  passwordHash              String?
  mustChangePassword        Boolean                   @default(false)
  passwordUpdatedAt         DateTime?
  realName                  String
  studentId                 String?                   @unique
  avatarUrl                 String?
  bio                       String?
  emailReminderEnabled      Boolean                   @default(true)
  lastExternalMailReminderAt DateTime?
  keycloakUserId            String?                   @unique
  mailboxProvisioningStatus MailboxProvisioningStatus @default(PENDING)
  mailboxProvisionedAt      DateTime?
  mailboxLastError          String?
  status                    UserStatus                @default(PENDING)
  archivedAt                DateTime?
  archiveExpiresAt          DateTime?
  contentRestoredAt         DateTime?
  memberships               UserGroupMembership[]
  roles                     UserRole[]
  authoredPages             KnowledgePage[]           @relation("KnowledgePageAuthor")
  editedPages               KnowledgePage[]           @relation("KnowledgePageEditor")
  pageEditGrants            KnowledgePageEditGrant[]  @relation("KnowledgePageEditGrantUser")
  grantedPageEditGrants     KnowledgePageEditGrant[]  @relation("KnowledgePageEditGrantGrantor")
  requestedPageAccesses     KnowledgePageAccessRequest[] @relation("KnowledgePageAccessRequester")
  reviewablePageAccesses    KnowledgePageAccessRequest[] @relation("KnowledgePageAccessReviewer")
  createdMailThreads        InternalMailThread[]      @relation("InternalMailThreadCreator")
  sentInternalMailMessages  InternalMailMessage[]     @relation("InternalMailMessageSender")
  internalMailRecipients    InternalMailRecipient[]   @relation("InternalMailRecipientUser")
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([archivedAt])
  @@index([archiveExpiresAt])
  @@index([contentRestoredAt])
  @@index([lastExternalMailReminderAt])
}

model Role {
  id          String     @id @default(cuid())
  code        String     @unique
  name        String
  description String?
  isSystem    Boolean    @default(false)
  users       UserRole[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model Group {
  id              String                @id @default(cuid())
  code            String                @unique
  name            String
  type            GroupType
  description     String?
  parentId        String?
  parent          Group?                @relation("GroupHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        Group[]               @relation("GroupHierarchy")
  memberships     UserGroupMembership[]
  knowledgeSpaces KnowledgeSpace[]
  knowledgeSpaceAccesses KnowledgeSpaceAccessGroup[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([type])
  @@index([parentId])
}

model UserGroupMembership {
  id             String         @id @default(cuid())
  userId         String
  groupId        String
  membershipRole MembershipRole @default(MEMBER)
  joinedAt       DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  group          Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
}

model KnowledgeSpace {
  id           String          @id @default(cuid())
  code         String          @unique
  slug         String          @unique
  name         String
  description  String?
  visibility   SpaceVisibility @default(PUBLIC)
  ownerGroupId String?
  parentSpaceId String?
  deletedAt    DateTime?
  deleteExpiresAt DateTime?
  ownerGroup   Group?          @relation(fields: [ownerGroupId], references: [id], onDelete: SetNull)
  parentSpace  KnowledgeSpace? @relation("KnowledgeSpaceHierarchy", fields: [parentSpaceId], references: [id], onDelete: SetNull)
  childSpaces  KnowledgeSpace[] @relation("KnowledgeSpaceHierarchy")
  accessGroups KnowledgeSpaceAccessGroup[]
  pages        KnowledgePage[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([ownerGroupId])
  @@index([parentSpaceId])
  @@index([deletedAt])
  @@index([deleteExpiresAt])
}

model KnowledgeSpaceAccessGroup {
  id        String         @id @default(cuid())
  spaceId    String
  groupId    String
  space      KnowledgeSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  group      Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([spaceId, groupId])
  @@index([spaceId])
  @@index([groupId])
}

model KnowledgePage {
  id             String         @id @default(cuid())
  spaceId        String
  parentId       String?
  authorId       String?
  editorId       String?
  title          String
  slug           String
  summary        String?
  contentMd      String
  contentRawJson Json?
  tags           String[]
  status         PageStatus     @default(DRAFT)
  sortOrder      Int            @default(0)
  publishedAt    DateTime?
  deletedAt      DateTime?
  deleteExpiresAt DateTime?
  space          KnowledgeSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  parent         KnowledgePage? @relation("KnowledgePageTree", fields: [parentId], references: [id], onDelete: SetNull)
  children       KnowledgePage[] @relation("KnowledgePageTree")
  author         User?          @relation("KnowledgePageAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  editor         User?          @relation("KnowledgePageEditor", fields: [editorId], references: [id], onDelete: SetNull)
  editGrants     KnowledgePageEditGrant[]
  accessRequests KnowledgePageAccessRequest[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([spaceId, slug])
  @@index([spaceId])
  @@index([parentId])
  @@index([spaceId, parentId])
  @@index([authorId])
  @@index([editorId])
  @@index([status])
  @@index([deletedAt])
  @@index([deleteExpiresAt])
}

model KnowledgePageEditGrant {
  id          String        @id @default(cuid())
  pageId       String
  userId       String
  grantedById  String
  page         KnowledgePage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user         User          @relation("KnowledgePageEditGrantUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy    User          @relation("KnowledgePageEditGrantGrantor", fields: [grantedById], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([pageId, userId])
  @@index([pageId])
  @@index([userId])
  @@index([grantedById])
}

model KnowledgePageAccessRequest {
  id             String                          @id @default(cuid())
  pageId          String
  requesterId     String
  reviewerId      String
  reviewerKind    KnowledgePageAccessApproverKind
  status          KnowledgePageAccessRequestStatus @default(PENDING)
  reason          String?
  reviewComment   String?
  reviewedAt      DateTime?
  page            KnowledgePage                   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  requester       User                            @relation("KnowledgePageAccessRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  reviewer        User                            @relation("KnowledgePageAccessReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  createdAt       DateTime                        @default(now())
  updatedAt       DateTime                        @updatedAt

  @@index([pageId])
  @@index([requesterId, status])
  @@index([reviewerId, status])
}

model InternalMailThread {
  id            String                @id @default(cuid())
  subject       String
  createdById   String
  lastMessageAt DateTime
  createdBy     User                  @relation("InternalMailThreadCreator", fields: [createdById], references: [id], onDelete: Cascade)
  messages      InternalMailMessage[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([createdById])
  @@index([lastMessageAt])
}

model InternalMailMessage {
  id                  String                  @id @default(cuid())
  threadId            String
  senderId            String
  subject             String
  bodyMarkdown        String
  draftToUserIds      String[]
  draftCcUserIds      String[]
  draftToGroupIds     String[]
  draftCcGroupIds     String[]
  sentAt              DateTime?
  isDraft             Boolean                 @default(false)
  replyToMessageId    String?
  forwardOfMessageId  String?
  thread              InternalMailThread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender              User                    @relation("InternalMailMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  replyToMessage      InternalMailMessage?    @relation("InternalMailReplyChain", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replyMessages       InternalMailMessage[]   @relation("InternalMailReplyChain")
  forwardOfMessage    InternalMailMessage?    @relation("InternalMailForwardChain", fields: [forwardOfMessageId], references: [id], onDelete: SetNull)
  forwardedMessages   InternalMailMessage[]   @relation("InternalMailForwardChain")
  recipients          InternalMailRecipient[]
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([threadId])
  @@index([senderId])
  @@index([sentAt])
  @@index([isDraft])
  @@index([replyToMessageId])
  @@index([forwardOfMessageId])
}

model InternalMailRecipient {
  id                 String                         @id @default(cuid())
  messageId          String
  userId             String
  recipientType      InternalMailRecipientType
  deliverySourceType InternalMailDeliverySourceType
  deliverySourceId   String?
  readAt             DateTime?
  starredAt          DateTime?
  archivedAt         DateTime?
  deletedAt          DateTime?
  message            InternalMailMessage            @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user               User                           @relation("InternalMailRecipientUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt

  @@unique([messageId, userId, recipientType])
  @@index([userId])
  @@index([recipientType])
  @@index([deliverySourceType, deliverySourceId])
  @@index([readAt])
  @@index([starredAt])
  @@index([archivedAt])
  @@index([deletedAt])
}
